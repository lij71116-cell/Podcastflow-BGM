# 服务（8098/8099 占用时可改为 8100）
HOST=127.0.0.1
PORT=8100
DEBUG=true

# CORS（逗号分隔，需包含前端 dev 端口如 5201）
CORS_ORIGINS=http://localhost:5199,http://127.0.0.1:5199,http://localhost:5175,http://127.0.0.1:5175,http://localhost:5201,http://127.0.0.1:5201

# 数据与存储（T-006 起使用）
DATABASE_PATH=backend/data/podcast_flow.db
STORAGE_ROOT=backend/storage

# Session 签名密钥（T-007 起使用，请替换为随机字符串）
SESSION_SECRET=
SESSION_COOKIE_NAME=podcast_flow_session

# FFmpeg（系统 PATH 中的可执行文件名或绝对路径）
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# BGM 上传大小上限（MB）
MAX_BGM_FILE_SIZE_MB=50

# 混音合成超时（秒，默认 30 分钟）
MIX_TIMEOUT_SECONDS=1800
